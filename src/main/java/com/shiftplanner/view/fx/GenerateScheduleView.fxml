<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- ============================================================
     GENERATE SCHEDULE VIEW — layout con sidebar + area centrale
     ============================================================ -->
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.shiftplanner.controller.gui.fx.GenerateScheduleGUIControllerFX"
      prefWidth="980"
      prefHeight="680"
      style="-fx-background-color: #F7F8FA;">

    <!-- ── SIDEBAR ── -->
    <VBox prefWidth="160"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #E2E8F0;
                 -fx-border-width: 0 1 0 0;
                 -fx-padding: 0;">

        <!-- Logo nella sidebar -->
        <HBox style="-fx-padding: 18 16 18 16; -fx-alignment: CENTER_LEFT; -fx-spacing: 6;">
            <Label text="ShiftPlanner"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
        </HBox>

        <!-- Voci menu -->
        <VBox spacing="2" style="-fx-padding: 4 8 4 8;">
            <HBox style="-fx-padding: 9 10 9 10; -fx-spacing: 8; -fx-alignment: CENTER_LEFT;">
                <Label text="⌂" style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
                <Label text="Home" style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
            </HBox>
            <HBox style="-fx-padding: 9 10 9 10; -fx-spacing: 8; -fx-alignment: CENTER_LEFT;">
                <Label text="👤" style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
                <Label text="Employees" style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
            </HBox>
            <!-- Voce attiva -->
            <HBox style="-fx-background-color: #EBF4FF;
                         -fx-background-radius: 6;
                         -fx-padding: 9 10 9 10;
                         -fx-spacing: 8;
                         -fx-alignment: CENTER_LEFT;">
                <Label text="📅" style="-fx-font-size: 13;"/>
                <Label text="Schedule"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2563EB;"/>
            </HBox>
            <HBox style="-fx-padding: 9 10 9 10; -fx-spacing: 8; -fx-alignment: CENTER_LEFT;">
                <Label text="📋" style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
                <Label text="Requests" style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
            </HBox>
            <HBox style="-fx-padding: 9 10 9 10; -fx-spacing: 8; -fx-alignment: CENTER_LEFT;">
                <Label text="🔔" style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
                <Label text="Notifications" style="-fx-font-size: 13; -fx-text-fill: #718096;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- ── AREA PRINCIPALE ── -->
    <VBox HBox.hgrow="ALWAYS" spacing="0"
          style="-fx-background-color: #F7F8FA;">

        <!-- TOPBAR -->
        <HBox style="-fx-background-color: #FFFFFF;
                     -fx-border-color: #E2E8F0;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 12 24 12 24;
                     -fx-alignment: CENTER_LEFT;
                     -fx-spacing: 8;">
            <Label text="ShiftPlanner"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
            <Label text="Coordinator Portal"
                   style="-fx-font-size: 12; -fx-text-fill: #718096;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="🔔" style="-fx-font-size: 16; -fx-text-fill: #718096;"/>
            <Label text="Admin User"
                   style="-fx-font-size: 13; -fx-text-fill: #4A5568; -fx-padding: 0 6 0 6;"/>
            <Button text="Logout"
                    onAction="#onLogoutClicked"
                    style="-fx-background-color: #EF4444;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-border-radius: 6;
                           -fx-background-radius: 6;
                           -fx-padding: 6 14 6 14;
                           -fx-cursor: hand;"/>
        </HBox>

        <!-- CONTENUTO SCROLLABILE -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: #F7F8FA;
                           -fx-border-color: transparent;">
            <VBox spacing="16" style="-fx-padding: 24;">

                <!-- Titolo pagina -->
                <HBox style="-fx-alignment: CENTER_LEFT; -fx-spacing: 10;">
                    <Label text="&#8249;"
                           style="-fx-font-size: 20; -fx-text-fill: #718096;"/>
                    <Label text="Generate &amp; Edit Schedule"
                           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
                </HBox>

                <!-- Card Schedule Settings -->
                <VBox spacing="14"
                      style="-fx-background-color: #FFFFFF;
                             -fx-border-color: #E2E8F0;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 20;">
                    <Label text="Schedule Settings"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>

                    <HBox spacing="16" style="-fx-alignment: CENTER_LEFT;">
                        <!-- Periodo -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Start Date (YYYY-MM-DD)"
                                   style="-fx-font-size: 12; -fx-text-fill: #4A5568;"/>
                            <TextField fx:id="startDateField"
                                       promptText="es. 2026-06-01"
                                       style="-fx-background-color: #FFFFFF;
                                              -fx-border-color: #CBD5E0;
                                              -fx-border-radius: 5;
                                              -fx-background-radius: 5;
                                              -fx-font-size: 13;
                                              -fx-padding: 8 10 8 10;"
                                       maxWidth="Infinity"/>
                        </VBox>
                        <!-- Fine -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="End Date (YYYY-MM-DD)"
                                   style="-fx-font-size: 12; -fx-text-fill: #4A5568;"/>
                            <TextField fx:id="endDateField"
                                       promptText="es. 2026-06-07"
                                       style="-fx-background-color: #FFFFFF;
                                              -fx-border-color: #CBD5E0;
                                              -fx-border-radius: 5;
                                              -fx-background-radius: 5;
                                              -fx-font-size: 13;
                                              -fx-padding: 8 10 8 10;"
                                       maxWidth="Infinity"/>
                        </VBox>
                        <!-- Bottone Genera -->
                        <VBox spacing="6">
                            <Label text=" " style="-fx-font-size: 12;"/>
                            <Button text="Generate Schedule"
                                    onAction="#onGenerateClicked"
                                    style="-fx-background-color: #3B82F6;
                                           -fx-text-fill: #FFFFFF;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13;
                                           -fx-background-radius: 5;
                                           -fx-padding: 9 18 9 18;
                                           -fx-cursor: hand;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Banner Draft Mode / Summary -->
                <Label fx:id="summaryLabel"
                       style="-fx-background-color: #FEFCE8;
                              -fx-border-color: #FDE047;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-padding: 12 16 12 16;
                              -fx-text-fill: #92400E;
                              -fx-font-size: 13;"
                       visible="false" managed="false"
                       wrapText="true" maxWidth="Infinity"/>

                <!-- Messaggi errore / successo -->
                <Label fx:id="errorLabel"
                       style="-fx-text-fill: #E53E3E; -fx-font-size: 12;
                              -fx-background-color: #FFF5F5;
                              -fx-border-color: #FC8181;
                              -fx-border-radius: 5;
                              -fx-background-radius: 5;
                              -fx-padding: 8 12 8 12;"
                       visible="false" managed="false"
                       wrapText="true" maxWidth="Infinity"/>
                <Label fx:id="successLabel"
                       style="-fx-text-fill: #276749; -fx-font-size: 12;
                              -fx-background-color: #F0FFF4;
                              -fx-border-color: #9AE6B4;
                              -fx-border-radius: 5;
                              -fx-background-radius: 5;
                              -fx-padding: 8 12 8 12;"
                       visible="false" managed="false"
                       wrapText="true" maxWidth="Infinity"/>

                <!-- Card Tabella turni -->
                <VBox spacing="12"
                      style="-fx-background-color: #FFFFFF;
                             -fx-border-color: #E2E8F0;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 4 0 0 0;">
                    <TableView fx:id="shiftsTable" prefHeight="320"
                               style="-fx-background-color: transparent;
                                      -fx-border-color: transparent;">
                        <placeholder>
                            <Label text="Insert dates and click 'Generate Schedule'"
                                   style="-fx-text-fill: #A0AEC0; -fx-font-style: italic;"/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="dateColumn"      text="Date"      prefWidth="110"/>
                            <TableColumn fx:id="slotColumn"      text="Slot"      prefWidth="100"/>
                            <TableColumn fx:id="startTimeColumn" text="Start"     prefWidth="80"/>
                            <TableColumn fx:id="endTimeColumn"   text="End"       prefWidth="80"/>
                            <TableColumn fx:id="employeeColumn"  text="Employee"  prefWidth="220"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Modifica turno selezionato -->
                <HBox spacing="12" style="-fx-alignment: CENTER_LEFT;">
                    <Label text="New Employee ID:"
                           style="-fx-font-size: 13; -fx-text-fill: #4A5568;"/>
                    <TextField fx:id="employeeIdField"
                               promptText="e.g. 3"
                               prefWidth="80"
                               style="-fx-background-color: #FFFFFF;
                                      -fx-border-color: #CBD5E0;
                                      -fx-border-radius: 5;
                                      -fx-background-radius: 5;
                                      -fx-font-size: 13;
                                      -fx-padding: 7 10 7 10;"/>
                    <Button text="Modify Selected Shift"
                            onAction="#onModifyShiftClicked"
                            style="-fx-background-color: #FFFFFF;
                                   -fx-border-color: #CBD5E0;
                                   -fx-border-radius: 5;
                                   -fx-background-radius: 5;
                                   -fx-text-fill: #4A5568;
                                   -fx-font-size: 13;
                                   -fx-padding: 7 16 7 16;
                                   -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </ScrollPane>

        <!-- FOOTER con bottoni Discard/Publish -->
        <HBox style="-fx-background-color: #FFFFFF;
                     -fx-border-color: #E2E8F0;
                     -fx-border-width: 1 0 0 0;
                     -fx-padding: 14 24 14 24;
                     -fx-alignment: CENTER_RIGHT;
                     -fx-spacing: 12;">
            <Button text="Discard Draft"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #CBD5E0;
                           -fx-border-radius: 5;
                           -fx-background-radius: 5;
                           -fx-text-fill: #4A5568;
                           -fx-font-size: 13;
                           -fx-padding: 9 20 9 20;
                           -fx-cursor: hand;"
                    onAction="#onDiscardDraftClicked"/>
            <Button text="Publish Schedule"
                    onAction="#onPublishClicked"
                    style="-fx-background-color: #16A34A;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-weight: bold;
                           -fx-font-size: 13;
                           -fx-background-radius: 5;
                           -fx-padding: 9 20 9 20;
                           -fx-cursor: hand;"/>
        </HBox>

    </VBox>
</HBox>

